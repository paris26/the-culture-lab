---
import Link from '@/components/Link.astro'
import ThemeToggle from '@/components/ThemeToggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
---

<div class="border-b border-border/50">
  <div
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-4"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
      <span class="text-foreground font-mono text-xs font-bold tracking-widest uppercase"
        >{SITE.title}</span
      >
    </Link>
    <div class="flex items-center gap-6">
      <nav class="flex items-center gap-6 font-mono text-xs tracking-wider uppercase">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-muted-foreground hover:text-foreground transition-colors duration-300"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <div class="bg-border/50 h-4 w-px"></div>
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>
