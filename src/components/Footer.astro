---
import { SOCIAL_LINKS } from '@/consts'
import Link from './Link.astro'
import SocialIcons from './SocialIcons.astro'
---

<footer class="border-t border-border/50">
  <div
    class="mx-auto flex w-full max-w-6xl flex-col items-center justify-between gap-y-4 px-6 py-8 sm:flex-row"
  >
    <div class="flex flex-col gap-1">
      <span class="text-foreground font-mono text-xs font-bold tracking-widest uppercase">
        The Culture
      </span>
      <span class="text-muted-foreground text-xs">
        &copy; {new Date().getFullYear()} All rights reserved.
      </span>
    </div>
    <SocialIcons links={SOCIAL_LINKS} />
  </div>
</footer>
